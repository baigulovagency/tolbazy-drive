{
  "name": "tolbazy-drive",
  "private": true,
  "version": "0.1.0",
  "description": "Telegram taxi aggregator for Tolbazy and Aurgazinsky district.",
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:admin",
    "dev:api": "tsx watch apps/api/src/index.ts",
    "dev:admin": "next dev apps/admin",
    "start:api": "node dist/apps/api/src/index.js",
    "start:admin": "next start apps/admin",
    "build": "npm run build:api && npm run build:admin",
    "build:api": "tsc -p apps/api/tsconfig.json",
    "build:admin": "next build apps/admin",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/env": "^5.0.2",
    "@prisma/client": "^6.1.0",
    "fastify": "^5.2.1",
    "grammy": "^1.34.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "npm-run-all": "^4.1.5",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
